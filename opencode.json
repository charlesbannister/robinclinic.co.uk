{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "rm -rf /*": "deny",
      "rm -rf /": "deny",
      "rm -rf ~/*": "deny",
      "rm -rf ~": "deny",
      "sudo *": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git push origin :*": "deny"
    },
    "external_directory": {
      "*": "deny"
    }
  }
}
